{
  "id": "basic-img2img",
  "titleZh": "基礎圖生圖",
  "descriptionZh": "載入參考圖 → VAE 編碼 → KSampler（可調 denoise）；執行時由伺服器上傳參考圖並寫入 LoadImage。",
  "tags": ["img2img", "ksampler"],
  "requiredPacks": [],
  "whitelistParams": {
    "ckpt_name": {
      "nodeId": "4",
      "inputKey": "ckpt_name",
      "type": "string",
      "descriptionEn": "ComfyUI models/checkpoints filename"
    },
    "positive_prompt": {
      "nodeId": "6",
      "inputKey": "text",
      "type": "string",
      "descriptionEn": "Positive CLIP prompt"
    },
    "negative_prompt": {
      "nodeId": "7",
      "inputKey": "text",
      "type": "string",
      "descriptionEn": "Negative CLIP prompt"
    },
    "steps": {
      "nodeId": "3",
      "inputKey": "steps",
      "type": "int",
      "min": 1,
      "max": 80,
      "descriptionEn": "KSampler steps"
    },
    "cfg": {
      "nodeId": "3",
      "inputKey": "cfg",
      "type": "float",
      "min": 1,
      "max": 30,
      "descriptionEn": "CFG scale"
    },
    "seed": {
      "nodeId": "3",
      "inputKey": "seed",
      "type": "int",
      "min": 0,
      "max": 2147483647,
      "descriptionEn": "KSampler seed"
    },
    "denoise": {
      "nodeId": "3",
      "inputKey": "denoise",
      "type": "float",
      "min": 0.05,
      "max": 1,
      "descriptionEn": "Img2img denoise strength"
    },
    "sampler_name": {
      "nodeId": "3",
      "inputKey": "sampler_name",
      "type": "string",
      "descriptionEn": "KSampler sampler_name"
    },
    "scheduler": {
      "nodeId": "3",
      "inputKey": "scheduler",
      "type": "string",
      "descriptionEn": "KSampler scheduler"
    }
  },
  "workflow": {
    "10": {
      "class_type": "LoadImage",
      "inputs": {
        "image": "artai_img2img_placeholder.png"
      }
    },
    "11": {
      "class_type": "VAEEncode",
      "inputs": {
        "pixels": ["10", 0],
        "vae": ["4", 2]
      }
    },
    "3": {
      "class_type": "KSampler",
      "inputs": {
        "seed": 0,
        "steps": 20,
        "cfg": 7,
        "sampler_name": "euler",
        "scheduler": "normal",
        "denoise": 0.65,
        "model": ["4", 0],
        "positive": ["6", 0],
        "negative": ["7", 0],
        "latent_image": ["11", 0]
      }
    },
    "4": {
      "class_type": "CheckpointLoaderSimple",
      "inputs": {
        "ckpt_name": "model.safetensors"
      }
    },
    "6": {
      "class_type": "CLIPTextEncode",
      "inputs": {
        "text": "masterpiece, best quality",
        "clip": ["4", 1]
      }
    },
    "7": {
      "class_type": "CLIPTextEncode",
      "inputs": {
        "text": "text, watermark, low quality",
        "clip": ["4", 1]
      }
    },
    "8": {
      "class_type": "VAEDecode",
      "inputs": {
        "samples": ["3", 0],
        "vae": ["4", 2]
      }
    },
    "9": {
      "class_type": "SaveImage",
      "inputs": {
        "filename_prefix": "artai_basic_img2img",
        "images": ["8", 0]
      }
    }
  }
}
